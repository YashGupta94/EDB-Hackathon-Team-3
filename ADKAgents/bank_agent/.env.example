# Gemini API key (get one at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-api-key

# Google Cloud Project configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global

# Domain for Terraform to crawl when building the Vertex AI Search data store
# Run `uv run tf-deploy` after setting this, then paste the output into VERTEX_DATA_STORE_ID
WEBSITE_DOMAIN=www.example.com

# Populated after running `uv run tf-deploy`
VERTEX_DATA_STORE_ID=your-data-store-id

# BigQuery dataset IDs — each maps to a datasets/*.yaml file
BQ_DATASET=your-bank-dataset-id
ECOMMERCE_DATASET=your-ecommerce-dataset-id

# IAM member granted access via Terraform (e.g. user:you@example.com)
MEMBER_EMAIL=user:you@example.com

# Populated automatically by `uv run tf-deploy` — leave blank initially
CONTAINER_IMAGE=
